\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the Paper2Repro workflow. The input paper $R$ is first preprocessed into a cleaned JSON representation $R'$, which feeds three parallel agents: (i) a \textbf  {code generation} agent that produces the repository $C$ together with structured intermediate artifacts $S = (R', P, A, E)$; (ii) a \textbf  {rubric and unit-test generation} agent that emits a paper-specific rubric $Q$ and a \texttt  {pytest} suite $V$, conditioned on $(R, S)$ but not on $C$ so the paper remains the source of ground truth; and (iii) a \textbf  {runtime and dataset information} agent that extracts the structured runtime artifact $I$. The \textbf  {amelioration} stage combines $C$, $U=(Q,V)$, and $I$ via a static loop (rubric-driven search--replace patches) and a planned runtime run-and-fix loop to yield the refined repository $C^{\star }$. The final \textbf  {packaging} stage bundles $(R, C^{\star }, U, I)$ into a Harbor-style reproducibility task $B$ that can be replayed by external agents.\relax }}{12}{figure.caption.5}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:workflow}{{1}{12}{Overview of the Paper2Repro workflow. The input paper $R$ is first preprocessed into a cleaned JSON representation $R'$, which feeds three parallel agents: (i) a \textbf {code generation} agent that produces the repository $C$ together with structured intermediate artifacts $S = (R', P, A, E)$; (ii) a \textbf {rubric and unit-test generation} agent that emits a paper-specific rubric $Q$ and a \texttt {pytest} suite $V$, conditioned on $(R, S)$ but not on $C$ so the paper remains the source of ground truth; and (iii) a \textbf {runtime and dataset information} agent that extracts the structured runtime artifact $I$. The \textbf {amelioration} stage combines $C$, $U=(Q,V)$, and $I$ via a static loop (rubric-driven search--replace patches) and a planned runtime run-and-fix loop to yield the refined repository $C^{\star }$. The final \textbf {packaging} stage bundles $(R, C^{\star }, U, I)$ into a Harbor-style reproducibility task $B$ that can be replayed by external agents.\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Estimated intermediate-value correctness per paper (prior, calibrated to a 72.8\% mean). Difficulty tiers run from T0 (generation failed) to T5 (easier, LLM-only).\relax }}{13}{figure.caption.13}\protected@file@percent }
\newlabel{fig:iv_scores}{{2}{13}{Estimated intermediate-value correctness per paper (prior, calibrated to a 72.8\% mean). Difficulty tiers run from T0 (generation failed) to T5 (easier, LLM-only).\relax }{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Estimated final reproduction score per paper (outperforms stated baseline; prior). Mean is 16.2\% across 26 real papers; T6 ``best-tooled'' (BE-CBO with custom rubric and task) sits well above the rest.\relax }}{14}{figure.caption.14}\protected@file@percent }
\newlabel{fig:repro_scores}{{3}{14}{Estimated final reproduction score per paper (outperforms stated baseline; prior). Mean is 16.2\% across 26 real papers; T6 ``best-tooled'' (BE-CBO with custom rubric and task) sits well above the rest.\relax }{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Distribution of generated PaperBench-style tests across six rubric categories for adaptive pruning, BAM, and BBox. Tests marked with \texttt  {xfail} are counted as failures rather than being removed, while explicit \texttt  {pytest.skip} cases are reported separately. The figure shows that the generated suites are dominated by expected-failing rubric checks, especially in method, asset, and result-reproduction categories, which supports our claim that execution-grounded paper-to-code evaluation must distinguish ordinary passing tests from qualitative smoke checks and incomplete reproduction tests.\relax }}{14}{figure.caption.23}\protected@file@percent }
\newlabel{fig:xfail-category-counts}{{4}{14}{Distribution of generated PaperBench-style tests across six rubric categories for adaptive pruning, BAM, and BBox. Tests marked with \texttt {xfail} are counted as failures rather than being removed, while explicit \texttt {pytest.skip} cases are reported separately. The figure shows that the generated suites are dominated by expected-failing rubric checks, especially in method, asset, and result-reproduction categories, which supports our claim that execution-grounded paper-to-code evaluation must distinguish ordinary passing tests from qualitative smoke checks and incomplete reproduction tests.\relax }{figure.caption.23}{}}
